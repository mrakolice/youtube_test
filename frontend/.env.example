# Base URLs for each backend microservice (see docker-compose.yml ports).
# The frontend runs in the browser, outside the docker network, so these
# must be host-reachable URLs, not internal service names.
VITE_AUTH_API_URL=http://localhost:8001
VITE_VIDEO_API_URL=http://localhost:8002
VITE_VIEW_API_URL=http://localhost:8003
VITE_LIKE_API_URL=http://localhost:8004
