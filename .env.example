# PostgreSQL
POSTGRES_USER=youtube_user
POSTGRES_PASSWORD=youtube_password
POSTGRES_DB=youtube_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_VIDEO_PROCESSED=video.processed
KAFKA_TOPIC_VIEW_RECORDED=view.recorded
KAFKA_TOPIC_LIKE_RECORDED=like.recorded

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Services
AUTH_SERVICE_URL=http://auth-service:8001
VIDEO_SERVICE_URL=http://video-service:8002
VIEW_SERVICE_URL=http://view-service:8003
LIKE_SERVICE_URL=http://like-service:8004

# Frontend
FRONTEND_URL=http://localhost:3000

# Backend
BACKEND_URL=http://localhost:8000
