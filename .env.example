# PostgreSQL
POSTGRES_USER=youtube_user
POSTGRES_PASSWORD=youtube_password
POSTGRES_DB=youtube_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Хостовый порт, на который проброшена постгря (docker-compose ports)
POSTGRES_EXTERNAL_PORT=5434

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
# Хостовый порт, на который проброшен redis (docker-compose ports)
REDIS_EXTERNAL_PORT=6380

# Kafka
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_BROKER=kafka:9092
# Хост, под которым брокер анонсирует себя клиентам вне docker-сети
KAFKA_ADVERTISED_HOST=localhost
# Хостовый порт для PLAINTEXT_HOST listener (docker-compose ports)
KAFKA_EXTERNAL_PORT=29092
KAFKA_TOPIC_VIDEO_PROCESSED=video.processed
KAFKA_TOPIC_VIEW_RECORDED=view.recorded
KAFKA_TOPIC_LIKE_RECORDED=like.recorded

# Zookeeper
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Services
AUTH_SERVICE_URL=http://auth-service:8001
VIDEO_SERVICE_URL=http://video-service:8002
VIEW_SERVICE_URL=http://view-service:8003
LIKE_SERVICE_URL=http://like-service:8004

# Хостовые порты сервисов (docker-compose ports), внутри контейнеров всегда 8000
AUTH_SERVICE_PORT=8001
VIDEO_SERVICE_PORT=8002
VIEW_SERVICE_PORT=8003
LIKE_SERVICE_PORT=8004

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# Backend
BACKEND_URL=http://localhost:8000
